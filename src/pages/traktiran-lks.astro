---
import Header from "@/components/traktiran/Header.astro";
import Detail from "@/components/traktiran/Detail.astro";
import Form from "@/components/traktiran/Form.svelte";
import List from "@/components/traktiran/List.svelte";
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Traktiran LKS"
  description="A little treat for the big wins. Come and celebrate with us!"
  image="/og-traktiran.png"
>
  <main>
    <Header />
    
    <div class="container">
      <div class="left-col">
        <List client:load />
      </div>
      <div class="right-col">
        <Detail />
        <Form client:load />
      </div>
    </div>
  </main>
</Layout>


<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap");

  body {
    font-family: "Plus Jakarta Sans", sans-serif;
    background-color: #fafafa;
    color: #1f2937;
    margin: 0;
    padding: 0;
  }

  main {
    min-height: 100vh;
    padding-bottom: 5rem;
  }

  .container {
    width: 95%;
    max-width: 1400px;
    display: flex;
    gap: 2.5rem;
    margin: 0 auto;
  }

  .left-col {
    flex: 2;
  }

  .right-col {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: sticky;
    top: 2rem;
    flex: 1;
  }

  @media (max-width: 1024px) {
    .container {
      flex-direction: column;
    }
    
    .right-col {
      position: static;
      order: -1; /* Move form and details above list on mobile if preferred, or keep as is */
    }
  }
</style>

