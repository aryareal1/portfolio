---
import { Calendar, Clock, MapPin, Soup } from "@lucide/astro";
---

<div class="detail-card">
  <h3 class="detail-title">Event Details</h3>
  <div class="info-list">
    <div class="info-item">
      <span class="icon"><Calendar size={20} /></span>
      <div class="text">
        <label>Date</label>
        <p>Sunday, 10 May 2026</p>
      </div>
    </div>
    <div class="info-item">
      <span class="icon"><Clock size={20} /></span>
      <div class="text">
        <label>Time</label>
        <p>12:30 WIB <small>(After Dhuhr)</small></p>
      </div>
    </div>
    <div class="info-item">
      <span class="icon"><Soup size={20} /></span>
      <div class="text">
        <label>Menu</label>
        <p>Mie Ayam De Noto</p>
      </div>
    </div>
    <div class="info-item">
      <span class="icon"><MapPin size={20} /></span>
      <div class="text">
        <label>Location</label>
        <p>Rumah Arya <small>(Wonomulyo, Simbangdesa, Tulis)</small></p>
      </div>
    </div>
    <div class="info-map">
      <iframe
        src="https://maps.google.com/maps?q=-6.948620108323083,109.81302996009627&t=&z=13&ie=UTF8&iwloc=&output=embed"
        width="100%"
        height="275"
        style="border: 0; border-radius: 10px"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
  </div>
</div>

<style>
  .detail-card {
    background: white;
    padding: 1.5rem;
    border-radius: 1rem;
    border: 1px solid #f3f4f6;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
  }

  .detail-title {
    font-size: 1.25rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    color: #111827;
    padding-bottom: 1rem;
    border-bottom: 1px solid #f3f4f6;
  }

  .info-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .info-item {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .icon {
    width: 36px;
    height: 36px;
    background: rgba(99, 102, 241, 0.1);
    color: #4f46e5;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .text label {
    display: block;
    font-size: 0.625rem;
    text-transform: uppercase;
    color: #9ca3af;
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-bottom: 0.125rem;
  }

  .text p {
    margin: 0;
    font-weight: 700;
    font-size: 0.875rem;
    color: #1f2937;
  }

  .text small {
    display: block;
    font-size: 0.75rem;
    color: #6b7280;
    font-weight: 400;
  }
</style>
